FoamFile
{
    version     2.0;
    format      ascii;
    class       volScalarField;
    object      alphat;
}
// Turbulent thermal diffusivity — zero everywhere (laminar simulation)

dimensions      [1 -1 -1 0 0 0 0];
internalField   uniform 0;

boundaryField
{
    inlet       { type calculated; value uniform 0; }
    outlet      { type calculated; value uniform 0; }
    topWall     { type symmetryPlane; }
    bottomWall  { type symmetryPlane; }
    finTop      { type calculated; value uniform 0; }
    finBottom   { type calculated; value uniform 0; }
    cylinder    { type calculated; value uniform 0; }
    defaultFaces{ type empty; }
}
