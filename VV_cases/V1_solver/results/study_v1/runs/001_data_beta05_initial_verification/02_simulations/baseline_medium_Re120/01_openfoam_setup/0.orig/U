FoamFile
{
    version     2.0;
    format      ascii;
    class       volVectorField;
    object      U;
}

dimensions      [0 1 -1 0 0 0 0];
internalField   uniform (0.151600000 0 0);

boundaryField
{
    inlet
    {
        type exprFixedValue;
        valueExpr "vector(0.151600000*(1.0 - pow(2.0*pos().y()/0.024000000, 2.0)), 0, 0)";
        value uniform (0 0 0);
    }
    outlet { type zeroGradient; }
    top { type noSlip; }
    bottom { type noSlip; }
    cylinder { type noSlip; }
    front { type empty; }
    back { type empty; }
}
