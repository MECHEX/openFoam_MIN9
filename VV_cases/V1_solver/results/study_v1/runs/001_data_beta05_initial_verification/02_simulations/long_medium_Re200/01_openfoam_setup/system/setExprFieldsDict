FoamFile
{
    version     2.0;
    format      ascii;
    class       dictionary;
    object      setExprFieldsDict;
}

readFields ( U );

expressions
(
    U
    {
        field U;
        create no;
        dimensions [0 1 -1 0 0 0 0];
        expression
        #{ vector
            (
                0.252666667*(1.0 - pow(2.0*pos().y()/0.024000000, 2.0)),
                0.0025*exp(-pow((pos().x()-0.012)/0.010, 2.0) - pow((pos().y()-0.0035)/0.0035, 2.0)),
                0
            )
        #};
    }
);
