FoamFile
{
    version     2.0;
    format      ascii;
    class       dictionary;
    object      blockMeshDict;
}

// ============================================================
// V1 — 2-D channel, blockage beta = D/H = 0.5
// Replicates Sahin & Owens (2004) geometry for solver verification.
//
// D = 0.012 m  =>  H = D/beta = 0.024 m  (no-slip walls top AND bottom)
// L_in = 8D = 0.096 m,  L_out = 20D = 0.240 m
// z-span: 0.010 m, 1 cell  (empty BC => 2-D)
//
// Background cell size ~ 2 mm  =>  168 x 12 x 1
// snappyHexMesh adds cylinder and BL on top of this.
// ============================================================

scale 1;

vertices
(
    (-0.096 -0.012 -0.005)   // 0
    ( 0.240 -0.012 -0.005)   // 1
    ( 0.240  0.012 -0.005)   // 2
    (-0.096  0.012 -0.005)   // 3
    (-0.096 -0.012  0.005)   // 4
    ( 0.240 -0.012  0.005)   // 5
    ( 0.240  0.012  0.005)   // 6
    (-0.096  0.012  0.005)   // 7
);

blocks
(
    // 168 x 12 x 1  (dx ~ 2 mm, dy = 2 mm, dz = 10 mm)
    hex (0 1 2 3 4 5 6 7) (168 12 1) simpleGrading (1 1 1)
);

edges ();

boundary
(
    inlet
    {
        type patch;
        faces ( (0 4 7 3) );
    }
    outlet
    {
        type patch;
        faces ( (1 2 6 5) );
    }
    // no-slip walls — KEY difference from V3/V4a which use symmetryPlane
    bottom
    {
        type wall;
        faces ( (0 1 5 4) );
    }
    top
    {
        type wall;
        faces ( (3 7 6 2) );
    }
    front
    {
        type empty;
        faces ( (0 3 2 1) );
    }
    back
    {
        type empty;
        faces ( (4 5 6 7) );
    }
);

mergePatchPairs ();
