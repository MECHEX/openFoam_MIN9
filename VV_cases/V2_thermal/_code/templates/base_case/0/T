FoamFile
{
    version     2.0;
    format      ascii;
    class       volScalarField;
    object      T;
}

dimensions      [0 0 0 1 0 0 0];
internalField   uniform 293.15;

boundaryField
{
    inlet
    {
        type        fixedValue;
        value       uniform 293.15;
    }
    outlet
    {
        type        inletOutlet;
        inletValue  uniform 293.15;
        value       uniform 293.15;
    }
    top
    {
        type        zeroGradient;
    }
    bottom
    {
        type        zeroGradient;
    }
    cylinder
    {
        type        fixedValue;
        value       uniform 303.15;
    }
    front
    {
        type        empty;
    }
    back
    {
        type        empty;
    }
}
